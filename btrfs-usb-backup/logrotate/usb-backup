/var/log/usb-backup/usb-backup.log
/var/log/usb-backup/usb-backup-error.log {

    monthly
    rotate 12
    compress
    missingok
    notifempty
    create 640 root root

}

/var/log/usb-backup/usb-backup-root-receive-dump.log
/var/log/usb-backup/usb-backup-home-receive-dump.log
/var/log/usb-backup/usb-backup-scrub-dump.log {

    monthly
    rotate 6
    compress
    missingok
    notifempty
    create 640 root root

}
